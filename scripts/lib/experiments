function __contains {
    local array_var=$1
    local elem="$2"

    local -n larray=$array_var

    local e
    for e in "${larray[@]}"; do
        [[ $e == $elem ]] && return 0
    done

    return 1
}

function _includes {
    local array_var1=$1
    local array_var2=$2

    local -n larray1=$array_var1
    local -n larray2=$array_var2

    local e
    for e in "${larray2[@]}"; do
        __contains $array_var1 "$e" && continue

        printf "Element '%s' of array %s is not included in array %s\n" "$e" $array_var2 $array_var1 >&2
        exit 9
    done

    return 0
}

